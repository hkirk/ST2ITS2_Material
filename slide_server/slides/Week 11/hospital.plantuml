@startuml

' Only greyscale
skinparam monochrome true
' Display UML icons (-, +, ~, #) instead of visibility icons
skinparam classAttributeIconSize 0
' Disable class / interface / ... icons
hide circles
' Hide empty boxes
hide empty fields
hide empty methods
' Display packages as frame
skinparam packageStyle frame
' Disable shadows
skinparam shadowing false


class Hospital {
        - HospitalName: string
        - _listOfStaff: Collection<HospitalStaff>

        + Hospital(hospitalName: string)
        + AddNewStaff(staff: HospitalStaff): void
        + SeeStaff(): void
        + GetDoctor(id: string): Doctor
        + AdmitPatient(firstName: string, lastName: string, ssn: Ssn, diagnosis: string): bool
    }

    abstract class HospitalStaff {
        # StaffId: string
        + FullName: string {get; private set;}

        + GetInfo(): StaffInfo
    }

    class Doctor {
        # Patients: Collection<Patient>
        + Specialization: ISpecialization {get; private set;}
        + AddNewPatient(patient: Patient): Patient {override}
        + GetPatients(): List<Patient>
        + SetSpecialization(specialization: ISpecializatation)
    }

    class Nurse {
      - section: Section

      + AssignToSection(section: Section): void
    }

    class Section {
       + SectionName: string {readonly}
       + Capacity: int {readonly}
    } 

    interface ISpecialization {
        + Name: string { get; set;}

        + GetPossibleDiagnoses(): List<string>
        + IsSuitableForDiagnosis(diagnosis: string): bool
    }

    class Oncologists {}
    class Allergist {}
    class Neurologist {}

    class Patient {
        + Ssn: Ssn {readonly}
        - age: int
        - FirstName: string;
        - LastName: string;
        + Record: Record {get; private set}

        + GetFullName(): string
    }

    class Record {
        + RecordId: int {readonly}
        + Diagnosis: string {get; private set}
        + AssignedDoctor: Doctor? {get; private set}
        + ValidateDoctorSpecialization(doctor: Doctor): bool
        + ChangeDiagnosis(diagnosis: string)
        + AssignDoctor(doctor: Doctor): void
    }

    Hospital "1" --> "0..*" HospitalStaff : _listOfStaff
    HospitalStaff <|-- Doctor
    HospitalStaff <|-- Nurse
    Hospital "1" --> "0..*" Section
    
    Nurse --> Section

    Doctor "1" --> "0..*" Patient : AddNewPatient
    Doctor "1" --> "1" ISpecialization : Specialization
    ISpecialization <|.. Oncologists
    ISpecialization <|.. Allergist
    ISpecialization <|.. Neurologist

    Patient *--> "1" Record : Record

note left of HospitalStaff::GetInfo 
  Class with readonly fields for StaffId and Name
end note

note left of Patient::Ssn 
  Class with Readonly field for Social Security number
end note

note left of Patient::Ssn 
  Class with Readonly field for Social Security number
end note

note left of Record::ValidateDoctorSpecialization
  Checks if the doctor's specialization is suitable for the patient's diagnosis.
  Uses ISpecialization.IsSuitableForDiagnosis(diagnosis: string).
  Assigned doctor should have a suitable specilization according to:
  https://www.webmd.com/health-insurance/insurance-doctor-types
  AssignedDoctor should be non-null after admission
end note

    note left of Patient : Age should be 0 <= age <= 120
    note left of Hospital::_listOfStaff
      Collection is a standin for any datatype that holds multiple
      elements, you choose the one you think is best suited. 
    end note
    note left of HospitalStaff::Patients
      Collection is a standin for any datatype that holds multiple
      elements, you choose the one you think is best suited.
    end note

    note left of Hospital::AdmitPatient
      1. Validates patient's Ssn and creates a new Record.
      2. Assigns a doctor based on specialization (if available).
      3. Returns true if successful, false otherwise.
    end note

@enduml